{
  "env": {
    "ENABLE_TOOL_SEARCH": "true",
    "BASH_MAX_OUTPUT_LENGTH": "150000"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Read(~/.claude)"
    ],
    "deny": [
      "Read(**/node_modules/**)",
      "Read(**/.svelte-kit/**)",
      "Read(**/dist/**)",
      "Read(**/build/**)",
      "Read(**/coverage/**)"
    ],
    "defaultMode": "auto"
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'if application \"iTerm2\" is not frontmost then display notification \"Claude Code is done\" with title \"Claude Code\" sound name \"Blow\"'"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'if application \"iTerm2\" is not frontmost then display notification \"Claude Code needs input\" with title \"Claude Code\" sound name \"Bottle\"'"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bunx ccusage@latest statusline --visual-burn-rate=emoji-text"
  },
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true,
    "php-lsp@claude-plugins-official": true,
    "lua-lsp@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "context-mode@context-mode": true,
    "pr-review-toolkit@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "claude-hud": {
      "source": {
        "source": "github",
        "repo": "jarrodwatts/claude-hud"
      }
    },
    "anthropic-agent-skills": {
      "source": {
        "source": "github",
        "repo": "anthropics/skills"
      }
    },
    "context-mode": {
      "source": {
        "source": "github",
        "repo": "mksglu/context-mode"
      }
    }
  },
  "effortLevel": "medium",
  "skipAutoPermissionPrompt": true,
  "voiceEnabled": true
}
