{
  "env": {
    "ENABLE_TOOL_SEARCH": "true",
    "BASH_MAX_OUTPUT_LENGTH": "150000"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Read(~/.claude)"
    ],
    "deny": [
      "Read(**/node_modules/**)",
      "Read(**/.svelte-kit/**)",
      "Read(**/dist/**)",
      "Read(**/build/**)",
      "Read(**/coverage/**)"
    ],
    "defaultMode": "auto"
  },
  "model": "sonnet[1m]",
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'if application \"iTerm2\" is not frontmost then display notification \"Claude Code is done\" with title \"Claude Code\" sound name \"Blow\"'"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/notify-needs-input"
          }
        ]
      }
    ],
    "PreToolUse": [],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"/Users/mikefunk/.claude/hooks/context-mode-cache-heal.mjs\""
          }
        ]
      }
    ],
    "PostToolUse": []
  },
  "statusLine": {
    "type": "command",
    "command": "bunx ccusage@latest statusline --visual-burn-rate=emoji-text"
  },
  "enabledPlugins": {
    "context-mode@context-mode": true,
    "saatchi-art-claude-plugins@local-desktop-app-uploads": true,
    "pr-review-toolkit@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "claude-hud": {
      "source": {
        "source": "github",
        "repo": "jarrodwatts/claude-hud"
      }
    },
    "anthropic-agent-skills": {
      "source": {
        "source": "github",
        "repo": "anthropics/skills"
      }
    },
    "context-mode": {
      "source": {
        "source": "github",
        "repo": "mksglu/context-mode"
      }
    }
  },
  "effortLevel": "low",
  "voiceEnabled": true,
  "skipAutoPermissionPrompt": true,
  "theme": "auto"
}
