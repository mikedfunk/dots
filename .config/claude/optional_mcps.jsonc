{
    "context7": {
        "command": "bunx",
        "args": [
            "--bun",
            "@upstash/context7-mcp@latest"
        ]
    },
    "habitica": {
        "command": "bunx",
        "args": [
            "--bun",
            // "github:siddhero97/habitica-mcp-server#fixingClientHeader"
            "github:mikedfunk/habitica-mcp-server#v0.2.4"
        ]
    },
    "gmail": {
        "command": "bunx",
        "args": [
            "--bun",
            // TODO: archived - look for a working fork
            "@gongrzhe/server-gmail-autoauth-mcp@latest",
            // "maintained fork" but not on npm and github version doesn't work :/
            // "@ArtyMcLabin/Gmail-MCP-Server@latest",
            "--client",
            "claude"
        ]
    },
    // "coderabbitai": {
    //     "command": "bunx",
    //     "args": [
    //         "--bun",
    //         "coderabbitai-mcp@latest"
    //     ],
    //     "env": {
    //         "GITHUB_PAT": "$GITHUB_TOKEN"
    //     }
    // },
    "figma": {
        "type": "http",
        "url": "https://mcp.figma.com/mcp"
    },
    "sentry": {
        "type": "http",
        "url": "https://mcp.sentry.dev/mcp"
    },
    // NOTE: requires Spotify premium
    // "spotify": {
    //     "command": "uvx",
    //     "args": [
    //         "--python",
    //         "3.12",
    //         "--from",
    //         "git+https://github.com/varunneal/spotify-mcp",
    //         "spotify-mcp"
    //     ],
    //     "env": {
    //         "SPOTIFY_CLIENT_ID": "$SPOTIFY_CLIENT_ID",
    //         "SPOTIFY_CLIENT_SECRET": "$SPOTIFY_CLIENT_SECRET",
    //         "SPOTIFY_REDIRECT_URI": "http://127.0.0.1:8039/callback"
    //     }
    // },
    "obsidian": {
        "command": "uvx",
        "args": [
            "--directory",
            "$HOME/Notes",
            "mcp-obsidian"
        ],
        "env": {
            "OBSIDIAN_API_KEY": "$OBSIDIAN_API_KEY"
        }
    },
    "snyk": {
        "command": "snyk",
        "args": [
            "mcp",
            "-t",
            "stdio"
        ]
    },
    "aws-knowledge-mcp-server": {
        "command": "uvx",
        "args": [
            "fastmcp",
            "run",
            "https://knowledge-mcp.global.api.aws"
        ]
    },
    "awslabs.eks-mcp-server": {
        "command": "uvx",
        "args": [
            "awslabs.eks-mcp-server@latest",
            "--allow-sensitive-data-access"
        ],
        "env": {
            "FASTMCP_LOG_LEVEL": "ERROR",
            "AWS_PROFILE": "$AWS_PROFILE"
        }
    },
    "awslabs.cloudwatch-mcp-server": {
        "command": "uvx",
        "args": [
            "awslabs.cloudwatch-mcp-server@latest"
        ],
        "env": {
            "AWS_PROFILE": "$AWS_PROFILE",
            "FASTMCP_LOG_LEVEL": "ERROR"
        }
    },
    "awslabs.cost-explorer-mcp-server": {
        "command": "uvx",
        "args": [
            "awslabs.cost-explorer-mcp-server@latest"
        ],
        "env": {
            "FASTMCP_LOG_LEVEL": "ERROR",
            "AWS_PROFILE": "$AWS_PROFILE"
        }
    },
    "apple-mcp": {
        "command": "bunx",
        "args": [
            "--bun",
            "apple-mcp@latest"
        ]
    },
    "github": {
        // NOTE: adds large context per call
        "type": "http",
        "url": "https://api.githubcopilot.com/mcp/",
        "headers": {
            "Authorization": "Bearer $GITHUB_TOKEN"
        }
    },
    "postman": {
        "type": "http",
        "url": "https://mcp.postman.com/minimal",
        "headers": {
            "Authorization": "Bearer $POSTMAN_API_TOKEN"
        }
    },
    "youtube-transcript": {
        "command": "uvx",
        "args": [
            "--from",
            "git+https://github.com/jkawamoto/mcp-youtube-transcript",
            "mcp-youtube-transcript"
        ]
    },
    // NOTE: Use Playwright instead of firefox-devtools for browser automation.
    // Playwright manages its own browser lifecycle (no pre-launch needed), supports
    // persistent sessions via --user-data-dir, and works with Chromium/Firefox/WebKit.
    "playwright": {
        "command": "bunx",
        "args": [
            "--bun",
            "@playwright/mcp@latest",
            "--browser",
            "chromium",
            "--user-data-dir",
            "$XDG_CONFIG_HOME/playwright-mcp"
        ]
    },
    "slack": {
        "command": "bunx",
        "args": [
            "--bun",
            "slack-mcp-server@latest",
            "--transport",
            "stdio"
        ],
        "env": {
            "SLACK_MCP_XOXC_TOKEN": "$SLACK_MCP_XOXC_TOKEN",
            "SLACK_MCP_XOXD_TOKEN": "$SLACK_MCP_XOXD_TOKEN",
            "SLACK_MCP_USER_AGENT": "Mozilla/5.0 (Macintosh; Intel Mac OS X 10.15; rv:144.0) Gecko/20100101 Firefox/144.0",
            "SLACK_MCP_ADD_MESSAGE_TOOL": "true",
            "SLACK_MCP_ADD_MESSAGE_UNFURLING": "true",
            // Cache channels for 30 days. Delete ~/Library/Caches/slack-mcp-server/T02*_channels_cache_v2.json to force refresh.
            "SLACK_MCP_CACHE_TTL": "720h"
        }
    },
    "atlassian": {
        "type": "http",
        "url": "https://mcp.atlassian.com/v1/mcp"
    },
    // NOTE: can't run with bunx yet because of this bug https://github.com/bitwarden/mcp-server/issues/158
    // WARNING: requires `export BW_SESSION=$(bw unlock --raw)`
    "bitwarden": {
        "type": "stdio",
        "command": "$HOME/.support/bitwarden-mcp-helper.sh",
        "env": {
            "BW_SESSION": "$BW_SESSION"
        }
    },
    // NOTE: requires storybook on local
    "storybook": {
        "type": "http",
        "url": "http://localhost:6006/mcp"
    },
    "tree-sitter": {
        "command": "uvx",
        "args": [
            "mcp-server-tree-sitter"
        ]
    },
    "cloudflare-observability": {
        "type": "http",
        "url": "https://observability.mcp.cloudflare.com/mcp"
    },
    "cloudflare-bindings": {
        "type": "http",
        "url": "https://bindings.mcp.cloudflare.com/mcp"
    },
